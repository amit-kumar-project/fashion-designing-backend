# Local Development Environment Configuration

# Server Configuration
PORT=8080
NODE_ENV=local

# Database Configuration - Local MongoDB
MONGODB_URI=mongodb://localhost:27017/fashionDesignDB

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:19006

# JWT Configuration
JWT_SECRET=local_jwt_secret_key_change_in_production
JWT_EXPIRE=30d

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# API Configuration
API_VERSION=v1
